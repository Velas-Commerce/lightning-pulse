LND_URL=https://your-vps-ip-or-hostname:8080
LND_READONLY_MACAROON_HEX=

# Local dev: path to cert file on disk
LND_TLS_CERT_PATH=tls.cert

# Production (Railway etc): base64-encoded cert — takes priority over LND_TLS_CERT_PATH
# Generate with: base64 -w0 tls.cert   (Linux/Mac) or [Convert]::ToBase64String([IO.File]::ReadAllBytes("tls.cert"))  (PowerShell)
TLS_CERT_B64=

# Comma-separated list of allowed frontend origins (defaults to localhost:5173)
CORS_ORIGINS=https://yourdomain.com
